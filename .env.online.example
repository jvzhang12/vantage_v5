OPENAI_API_KEY=
VANTAGE_V5_MODEL=gpt-4.1
VANTAGE_V5_HOST=0.0.0.0
VANTAGE_V5_PORT=8005

# Docker host interface for the published port. Keep loopback when a tunnel or
# reverse proxy runs on the same machine. Use 0.0.0.0 only for direct LAN access.
VANTAGE_V5_PUBLISH_HOST=127.0.0.1

VANTAGE_V5_REPO_ROOT=/data
VANTAGE_V5_ACTIVE_WORKSPACE=v5-milestone-1

# Required for any internet/LAN deployment unless you intentionally override
# the safety guard for a trusted private network.
VANTAGE_V5_AUTH_USERNAME=vantage
VANTAGE_V5_AUTH_PASSWORD=replace-with-a-long-random-password

# Optional multi-user profile mode. Prefer AUTH_USERS_FILE for real deploys
# so plaintext passwords do not sit in shell history.
VANTAGE_V5_AUTH_USERS_JSON=
VANTAGE_V5_AUTH_USERS_FILE=

# Set these when using a real domain or reverse proxy.
# Example:
# VANTAGE_V5_ALLOWED_HOSTS=vantage.example.com,localhost,127.0.0.1
# VANTAGE_V5_ALLOWED_ORIGINS=https://vantage.example.com
VANTAGE_V5_ALLOWED_HOSTS=
VANTAGE_V5_ALLOWED_ORIGINS=
VANTAGE_V5_COOKIE_SECURE=false

# Only set true for an isolated private network while testing.
VANTAGE_V5_ALLOW_UNSAFE_PUBLIC_NO_AUTH=false

VANTAGE_V5_NEXUS_ROOT=
VANTAGE_V5_NEXUS_INCLUDE=
VANTAGE_V5_NEXUS_EXCLUDE=
